# BMG-Harmony live store — never commit
# Ignore store contents but track .gitkeep so directory exists after clone
.harmony/store/*
!.harmony/store/.gitkeep
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo
